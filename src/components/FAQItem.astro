---
interface Props {
  question: string;
  answer: string;
}

const { question, answer } = Astro.props;

// Slug alone would collide for non-Latin questions (e.g. Chinese strips to ""),
// so append a hash of the full text to keep ids unique per question.
let hash = 0;
for (let i = 0; i < question.length; i++) {
  hash = (hash * 31 + question.charCodeAt(i)) >>> 0;
}
const slug = question.replace(/\s+/g, '-').replace(/[^a-zA-Z0-9-]/g, '').toLowerCase().slice(0, 32);
const faqId = `faq-${slug}-${hash.toString(36)}`;
---

<div class="faq-item">
  <button class="faq-item__question" id={`${faqId}-q`} aria-expanded="false" aria-controls={`${faqId}-a`}>
    <span>{question}</span>
    <span class="faq-item__icon" aria-hidden="true">+</span>
  </button>
  <div class="faq-item__answer" id={`${faqId}-a`} role="region" aria-labelledby={`${faqId}-q`}>
    <p>{answer}</p>
  </div>
</div>
