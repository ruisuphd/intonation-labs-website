---
import Base from '@/layouts/Base.astro';
import { t, localePath } from '@/i18n/index';
import Breadcrumb from '@/components/Breadcrumb.astro';
import ContactForm from '@/components/ContactForm.astro';

const lang = 'en';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Intonation Labs Pte. Ltd.',
  url: 'https://www.intonationlabs.com',
  contactPoint: {
    '@type': 'ContactPoint',
    email: 'info@intonationlabs.com',
    contactType: 'customer service',
    availableLanguage: ['English', 'Chinese'],
  },
};
---

<Base
  title={t(lang, 'page.contact.title')}
  description={t(lang, 'page.contact.desc')}
  lang={lang}
  jsonLd={jsonLd}
  canonicalPath="/contact"
>
  <Breadcrumb
    lang={lang}
    items={[
      { label: t(lang, 'breadcrumb.home'), href: localePath(lang, '/') },
      { label: t(lang, 'nav.contact') },
    ]}
  />

  <section class="section" aria-labelledby="contact-title">
    <div class="container">
      <div class="section__header reveal">
        <p class="section__label">{t(lang, 'contact.label')}</p>
        <h1 id="contact-title" class="section__title">{t(lang, 'contact.title')}</h1>
        <p class="section__subtitle">{t(lang, 'contact.subtitle')}</p>
      </div>

      <div class="contact__inner">
        <div class="reveal">
          <ContactForm lang={lang} />
        </div>

        <div class="reveal reveal-delay-1">
          <div class="contact__sidebar-block">
            <h3>{t(lang, 'contact.or')}</h3>

            <div class="contact__info-item">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M16 2v4"/><path d="M8 2v4"/><path d="M3 10h18"/></svg>
              <a href="https://calendar.app.google/JDEqiw8AM2UbtU6X6" target="_blank" rel="noopener noreferrer" class="btn btn--primary btn--sm" style="width:100%">{t(lang, 'contact.book')}</a>
            </div>

            <div class="contact__info-item">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              <a href="mailto:info@intonationlabs.com">info@intonationlabs.com</a>
            </div>

            <div class="contact__info-item">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              <a href="https://linkedin.com/in/rui-su-phd" target="_blank" rel="noopener noreferrer">LinkedIn</a>
            </div>

            <p class="contact__response-note">{t(lang, 'contact.response')}</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>
