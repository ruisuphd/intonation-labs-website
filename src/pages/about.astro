---
import Base from '@/layouts/Base.astro';
import { t, localePath } from '@/i18n/index';
import Breadcrumb from '@/components/Breadcrumb.astro';
import { publications, certifications, specialisations } from '@/data/profile';

const lang = 'en';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Rui Su',
  jobTitle: 'Founder & Director',
  worksFor: {
    '@type': 'Organization',
    name: 'Intonation Labs Pte. Ltd.',
    url: 'https://www.intonationlabs.com',
  },
  url: 'https://www.ruisuphd.com',
  alumniOf: [
    { '@type': 'CollegeOrUniversity', name: 'Maynooth University' },
    { '@type': 'CollegeOrUniversity', name: 'UC Davis' },
  ],
  sameAs: [
    'https://linkedin.com/in/rui-su-phd',
    'https://github.com/ruisuphd',
    'https://www.ruisuphd.com',
  ],
};
---

<Base
  title={t(lang, 'page.about.title')}
  description={t(lang, 'page.about.desc')}
  lang={lang}
  jsonLd={jsonLd}
  canonicalPath="/about"
>
  <Breadcrumb
    lang={lang}
    items={[
      { label: t(lang, 'breadcrumb.home'), href: localePath(lang, '/') },
      { label: t(lang, 'nav.about') },
    ]}
  />

  <section class="section" aria-labelledby="about-title">
    <div class="container">
      <div class="section__header reveal">
        <p class="section__label">{t(lang, 'about.label')}</p>
        <h1 id="about-title" class="section__title">{t(lang, 'about.title')}</h1>
      </div>

      <div class="about__inner">
        <div class="about__content reveal">
          <p class="about__name">{t(lang, 'about.name')}</p>
          <p>{t(lang, 'about.bio1')}</p>
          <p>{t(lang, 'about.bio2')}</p>
          <p>{t(lang, 'about.bio3')}</p>

          <div class="about__social">
            <a href="https://linkedin.com/in/rui-su-phd" target="_blank" rel="noopener noreferrer" class="about__social-link" aria-label="LinkedIn">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </a>
            <a href="https://github.com/ruisuphd" target="_blank" rel="noopener noreferrer" class="about__social-link" aria-label="GitHub">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            </a>
            <a href="https://www.ruisuphd.com" target="_blank" rel="noopener noreferrer" class="about__social-link" aria-label="Personal Website">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
            </a>
            <a href="mailto:info@intonationlabs.com" class="about__social-link" aria-label="Email">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            </a>
          </div>
        </div>

        <div class="about__sidebar reveal reveal-delay-1">
          <h3>{t(lang, 'about.certs')}</h3>
          <div class="about__certs">
            {certifications.map((cert) => <span class="cert-badge">{cert}</span>)}
          </div>

          <h3>{t(lang, 'about.specs')}</h3>
          <div class="about__certs">
            {specialisations.map((spec) => <span class="cert-badge">{spec}</span>)}
          </div>

          <h3>{t(lang, 'about.pubs')}</h3>
          <div class="about__pubs">
            {publications.map((pub) => (
              <div class="pub-item">
                <p class="pub-item__title">{pub.title}</p>
                <p class="pub-item__venue">{pub.venue}</p>
              </div>
            ))}
          </div>

          <h3>{t(lang, 'about.responsible')}</h3>
          <div class="about__responsible">
            <p>{t(lang, 'about.responsible.text')}</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>
