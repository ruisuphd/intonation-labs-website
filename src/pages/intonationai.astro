---
import Base from '@/layouts/Base.astro';
import { t, localePath } from '@/i18n/index';
import Breadcrumb from '@/components/Breadcrumb.astro';

const lang = 'en';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'IntonationAI',
  applicationCategory: 'MultimediaApplication',
  operatingSystem: 'Web',
  description: t(lang, 'page.intonationai.desc'),
  url: 'https://intonationai.app',
  creator: {
    '@type': 'Organization',
    name: 'Intonation Labs Pte. Ltd.',
    url: 'https://www.intonationlabs.com',
  },
  offers: [
    {
      '@type': 'Offer',
      name: 'Free',
      price: '0',
      priceCurrency: 'USD',
      availability: 'https://schema.org/OnlineOnly',
    },
    {
      '@type': 'Offer',
      name: 'Essential',
      price: '19',
      priceCurrency: 'USD',
      availability: 'https://schema.org/OnlineOnly',
    },
    {
      '@type': 'Offer',
      name: 'Pro',
      price: '29',
      priceCurrency: 'USD',
      availability: 'https://schema.org/OnlineOnly',
    },
  ],
};

const waveHeights = [15,25,40,55,70,50,80,60,90,75,95,80,65,45,60,75,85,55,40,65,80,50,35,55,70,45,30,50,25,15];
---

<Base
  title={t(lang, 'page.intonationai.title')}
  description={t(lang, 'page.intonationai.desc')}
  lang={lang}
  jsonLd={jsonLd}
  canonicalPath="/intonationai/"
>
  <Breadcrumb lang={lang} items={[
    { label: t(lang, 'breadcrumb.home'), href: localePath(lang, '/') },
    { label: 'IntonationAI' },
  ]} />

  <section class="section" aria-labelledby="product-title">
    <div class="container">
      <div class="section__header reveal">
        <p class="section__label">{t(lang, 'prod.label')}</p>
        <h1 id="product-title" class="section__title">{t(lang, 'prod.title')}</h1>
        <p class="section__subtitle">{t(lang, 'prod.subtitle')}</p>
      </div>

      <div class="product__inner">
        <div class="reveal">
          <div class="product__features">
            <div class="product__feature">
              <div class="product__feature-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="22"/></svg>
              </div>
              <div>
                <p class="product__feature-title">{t(lang, 'prod.f1.title')}</p>
                <p class="product__feature-desc">{t(lang, 'prod.f1.desc')}</p>
              </div>
            </div>
            <div class="product__feature">
              <div class="product__feature-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
              </div>
              <div>
                <p class="product__feature-title">{t(lang, 'prod.f2.title')}</p>
                <p class="product__feature-desc">{t(lang, 'prod.f2.desc')}</p>
              </div>
            </div>
            <div class="product__feature">
              <div class="product__feature-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>
              </div>
              <div>
                <p class="product__feature-title">{t(lang, 'prod.f3.title')}</p>
                <p class="product__feature-desc">{t(lang, 'prod.f3.desc')}</p>
              </div>
            </div>
            <div class="product__feature">
              <div class="product__feature-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
              </div>
              <div>
                <p class="product__feature-title">{t(lang, 'prod.f4.title')}</p>
                <p class="product__feature-desc">{t(lang, 'prod.f4.desc')}</p>
              </div>
            </div>
          </div>

          <p class="product__coming mt-xl">{t(lang, 'prod.coming')}</p>
          <p class="product__stack">{t(lang, 'prod.stack')}</p>

          <div class="mt-xl">
            <a href="https://intonationai.app" target="_blank" rel="noopener noreferrer" class="btn btn--primary">{t(lang, 'prod.cta')}</a>
          </div>
        </div>

        <div class="product__visual reveal reveal-delay-2">
          <div class="product__screen">
            <div class="product__screen-bar"><span></span><span></span><span></span></div>
            <div class="product__waveform" aria-hidden="true">
              {waveHeights.map((h) => <span style={`height:${h}%`} />)}
            </div>
            <div class="product__screen-label">{t(lang, 'prod.screen')}</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--alt" aria-labelledby="pricing-title">
    <div class="container">
      <div class="section__header text-center reveal">
        <h2 id="pricing-title" class="section__title">{t(lang, 'prod.pricing.title')}</h2>
      </div>
      <div class="pricing-grid pricing-grid--3 reveal reveal-delay-1">
        <div class="pricing-card">
          <p class="pricing-card__name">{t(lang, 'prod.pricing.free.name')}</p>
          <p class="pricing-card__price">{t(lang, 'prod.pricing.free.price')}</p>
          <p class="pricing-card__desc">{t(lang, 'prod.pricing.free.desc')}</p>
          <ul class="pricing-card__features">
            <li class="pricing-card__feature">{t(lang, 'prod.pricing.free.f1')}</li>
            <li class="pricing-card__feature">{t(lang, 'prod.pricing.free.f2')}</li>
            <li class="pricing-card__feature">{t(lang, 'prod.pricing.free.f3')}</li>
          </ul>
          <a href="https://intonationai.app" target="_blank" rel="noopener noreferrer" class="btn btn--outline btn--sm">{t(lang, 'pricing.cta.start')}</a>
        </div>
        <div class="pricing-card pricing-card--featured">
          <span class="pricing-card__badge">{t(lang, 'prod.pricing.popular')}</span>
          <p class="pricing-card__name">{t(lang, 'prod.pricing.essential.name')}</p>
          <p class="pricing-card__price">{t(lang, 'prod.pricing.essential.price')}</p>
          <p class="pricing-card__annual">{t(lang, 'prod.pricing.essential.annual')}</p>
          <p class="pricing-card__desc">{t(lang, 'prod.pricing.essential.desc')}</p>
          <ul class="pricing-card__features">
            <li class="pricing-card__feature">{t(lang, 'prod.pricing.essential.f1')}</li>
            <li class="pricing-card__feature">{t(lang, 'prod.pricing.essential.f2')}</li>
            <li class="pricing-card__feature">{t(lang, 'prod.pricing.essential.f3')}</li>
            <li class="pricing-card__feature">{t(lang, 'prod.pricing.essential.f4')}</li>
            <li class="pricing-card__feature">{t(lang, 'prod.pricing.essential.f5')}</li>
            <li class="pricing-card__feature">{t(lang, 'prod.pricing.essential.f6')}</li>
          </ul>
          <a href="https://intonationai.app" target="_blank" rel="noopener noreferrer" class="btn btn--primary btn--sm">{t(lang, 'pricing.cta.essential')}</a>
        </div>
        <div class="pricing-card">
          <p class="pricing-card__name">{t(lang, 'prod.pricing.pro.name')}</p>
          <p class="pricing-card__price">{t(lang, 'prod.pricing.pro.price')}</p>
          <p class="pricing-card__annual">{t(lang, 'prod.pricing.pro.annual')}</p>
          <p class="pricing-card__desc">{t(lang, 'prod.pricing.pro.desc')}</p>
          <ul class="pricing-card__features">
            <li class="pricing-card__feature">{t(lang, 'prod.pricing.pro.f1')}</li>
            <li class="pricing-card__feature">{t(lang, 'prod.pricing.pro.f2')}</li>
            <li class="pricing-card__feature">{t(lang, 'prod.pricing.pro.f3')}</li>
          </ul>
          <a href="https://intonationai.app" target="_blank" rel="noopener noreferrer" class="btn btn--primary btn--sm">{t(lang, 'pricing.cta.pro')}</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="partnership-title">
    <div class="container text-center">
      <div class="reveal">
        <h2 id="partnership-title" class="section__title">{t(lang, 'prod.partner')}</h2>
        <div class="mt-lg">
          <a href={localePath(lang, '/contact/')} class="btn btn--outline">{t(lang, 'prod.partner.cta')} <span class="arrow" aria-hidden="true">&rarr;</span></a>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-section" aria-labelledby="cta-title">
    <div class="container text-center">
      <h2 id="cta-title" class="section__title reveal">{t(lang, 'cta.title')}</h2>
      <p class="section__subtitle mx-auto reveal reveal-delay-1">{t(lang, 'cta.subtitle')}</p>
      <div class="cta__actions reveal reveal-delay-2">
        <a href="https://calendar.app.google/JDEqiw8AM2UbtU6X6" target="_blank" rel="noopener noreferrer" class="btn btn--primary btn--lg">{t(lang, 'cta.btn1')}</a>
        <a href={localePath(lang, '/contact/')} class="btn btn--outline-light btn--lg">{t(lang, 'cta.btn2')}</a>
      </div>
    </div>
  </section>
</Base>
