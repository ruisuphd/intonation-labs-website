---
import Base from '@/layouts/Base.astro';
import { t, localePath } from '@/i18n/index';
import Breadcrumb from '@/components/Breadcrumb.astro';

const lang = 'en';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'IntoMarketing',
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Web',
  description: t(lang, 'page.intomarketing.desc'),
  url: 'https://intomarketing.app',
  creator: {
    '@type': 'Organization',
    name: 'Intonation Labs Pte. Ltd.',
    url: 'https://www.intonationlabs.com',
  },
  offers: [
    {
      '@type': 'Offer',
      name: 'Starter',
      price: '0',
      priceCurrency: 'USD',
      availability: 'https://schema.org/OnlineOnly',
    },
    {
      '@type': 'Offer',
      name: 'Pro',
      price: '29',
      priceCurrency: 'USD',
      availability: 'https://schema.org/OnlineOnly',
    },
  ],
};

const steps = [
  { num: '01', label: 'Upload brand docs & connect platforms' },
  { num: '02', label: 'AI generates content for 6 platforms daily' },
  { num: '03', label: 'Review, approve & schedule in dashboard' },
  { num: '04', label: 'Track leads, intelligence & analytics' },
];
---

<Base
  title={t(lang, 'page.intomarketing.title')}
  description={t(lang, 'page.intomarketing.desc')}
  lang={lang}
  jsonLd={jsonLd}
  canonicalPath="/intomarketing/"
>
  <Breadcrumb lang={lang} items={[
    { label: t(lang, 'breadcrumb.home'), href: localePath(lang, '/') },
    { label: 'IntoMarketing' },
  ]} />

  <section class="section" aria-labelledby="product-title">
    <div class="container">
      <div class="section__header reveal">
        <p class="section__label">{t(lang, 'mkt.label')}</p>
        <h1 id="product-title" class="section__title">{t(lang, 'mkt.title')}</h1>
        <p class="section__subtitle">{t(lang, 'mkt.subtitle')}</p>
      </div>

      <div class="product__inner">
        <div class="reveal">
          <div class="product__features">
            <div class="product__feature">
              <div class="product__feature-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              </div>
              <div>
                <p class="product__feature-title">{t(lang, 'mkt.f1.title')}</p>
                <p class="product__feature-desc">{t(lang, 'mkt.f1.desc')}</p>
              </div>
            </div>
            <div class="product__feature">
              <div class="product__feature-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
              </div>
              <div>
                <p class="product__feature-title">{t(lang, 'mkt.f2.title')}</p>
                <p class="product__feature-desc">{t(lang, 'mkt.f2.desc')}</p>
              </div>
            </div>
            <div class="product__feature">
              <div class="product__feature-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </div>
              <div>
                <p class="product__feature-title">{t(lang, 'mkt.f3.title')}</p>
                <p class="product__feature-desc">{t(lang, 'mkt.f3.desc')}</p>
              </div>
            </div>
            <div class="product__feature">
              <div class="product__feature-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
              </div>
              <div>
                <p class="product__feature-title">{t(lang, 'mkt.f4.title')}</p>
                <p class="product__feature-desc">{t(lang, 'mkt.f4.desc')}</p>
              </div>
            </div>
            <div class="product__feature">
              <div class="product__feature-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              </div>
              <div>
                <p class="product__feature-title">{t(lang, 'mkt.f5.title')}</p>
                <p class="product__feature-desc">{t(lang, 'mkt.f5.desc')}</p>
              </div>
            </div>
            <div class="product__feature">
              <div class="product__feature-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 18a5 5 0 0 0-10 0"/><line x1="12" y1="9" x2="12" y2="2"/><line x1="4.22" y1="10.22" x2="5.64" y2="11.64"/><line x1="1" y1="18" x2="3" y2="18"/><line x1="21" y1="18" x2="23" y2="18"/><line x1="18.36" y1="11.64" x2="19.78" y2="10.22"/><line x1="23" y1="22" x2="1" y2="22"/><polyline points="16 5 12 9 8 5"/></svg>
              </div>
              <div>
                <p class="product__feature-title">{t(lang, 'mkt.f6.title')}</p>
                <p class="product__feature-desc">{t(lang, 'mkt.f6.desc')}</p>
              </div>
            </div>
          </div>

          <p class="product__coming mt-xl">{t(lang, 'mkt.coming')}</p>
          <p class="product__stack">{t(lang, 'mkt.stack')}</p>

          <div class="mt-xl product__cta-row">
            <a href="https://intomarketing.app" target="_blank" rel="noopener noreferrer" class="btn btn--primary">{t(lang, 'mkt.cta')}</a>
          </div>
        </div>

        <div class="product__visual reveal reveal-delay-2" aria-hidden="true">
          <div class="mkt__screen">
            <div class="product__screen-bar"><span></span><span></span><span></span></div>
            <div class="mkt__flow">
              {steps.map((s, i) => (
                <>
                  <div class="mkt__step">
                    <span class="mkt__step-num">{s.num}</span>
                    <span class="mkt__step-label">{s.label}</span>
                  </div>
                  {i < steps.length - 1 && <div class="mkt__arrow" aria-hidden="true">&#8595;</div>}
                </>
              ))}
            </div>
            <div class="product__screen-label">{t(lang, 'mkt.screen')}</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--alt" aria-labelledby="pricing-title">
    <div class="container">
      <div class="section__header text-center reveal">
        <h2 id="pricing-title" class="section__title">{t(lang, 'mkt.pricing.title')}</h2>
      </div>
      <div class="pricing-grid reveal reveal-delay-1">
        <div class="pricing-card">
          <p class="pricing-card__name">{t(lang, 'mkt.pricing.starter.name')}</p>
          <p class="pricing-card__price">{t(lang, 'mkt.pricing.starter.price')}</p>
          <p class="pricing-card__desc">{t(lang, 'mkt.pricing.starter.desc')}</p>
          <ul class="pricing-card__features">
            <li class="pricing-card__feature">{t(lang, 'mkt.pricing.starter.f1')}</li>
            <li class="pricing-card__feature">{t(lang, 'mkt.pricing.starter.f2')}</li>
            <li class="pricing-card__feature">{t(lang, 'mkt.pricing.starter.f3')}</li>
            <li class="pricing-card__feature">{t(lang, 'mkt.pricing.starter.f4')}</li>
          </ul>
          <a href="https://intomarketing.app" target="_blank" rel="noopener noreferrer" class="btn btn--outline btn--sm">{t(lang, 'pricing.cta.start')}</a>
        </div>
        <div class="pricing-card pricing-card--featured">
          <p class="pricing-card__name">{t(lang, 'mkt.pricing.pro.name')}</p>
          <p class="pricing-card__price">{t(lang, 'mkt.pricing.pro.price')}</p>
          <p class="pricing-card__desc">{t(lang, 'mkt.pricing.pro.desc')}</p>
          <ul class="pricing-card__features">
            <li class="pricing-card__feature">{t(lang, 'mkt.pricing.pro.f1')}</li>
            <li class="pricing-card__feature">{t(lang, 'mkt.pricing.pro.f2')}</li>
            <li class="pricing-card__feature">{t(lang, 'mkt.pricing.pro.f3')}</li>
            <li class="pricing-card__feature">{t(lang, 'mkt.pricing.pro.f4')}</li>
          </ul>
          <a href="https://intomarketing.app" target="_blank" rel="noopener noreferrer" class="btn btn--primary btn--sm">{t(lang, 'pricing.cta.pro')}</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="partnership-title">
    <div class="container text-center">
      <div class="reveal">
        <h2 id="partnership-title" class="section__title">{t(lang, 'mkt.partner')}</h2>
        <div class="mt-lg">
          <a href={localePath(lang, '/contact/')} class="btn btn--outline">{t(lang, 'mkt.partner.cta')} <span class="arrow" aria-hidden="true">&rarr;</span></a>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-section" aria-labelledby="cta-title">
    <div class="container text-center">
      <h2 id="cta-title" class="section__title reveal">{t(lang, 'cta.title')}</h2>
      <p class="section__subtitle mx-auto reveal reveal-delay-1">{t(lang, 'cta.subtitle')}</p>
      <div class="cta__actions reveal reveal-delay-2">
        <a href="https://calendar.app.google/JDEqiw8AM2UbtU6X6" target="_blank" rel="noopener noreferrer" class="btn btn--primary btn--lg">{t(lang, 'cta.btn1')}</a>
        <a href={localePath(lang, '/contact/')} class="btn btn--outline-light btn--lg">{t(lang, 'cta.btn2')}</a>
      </div>
    </div>
  </section>
</Base>
